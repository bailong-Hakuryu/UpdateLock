#include <winresrc.h>
#include <windows.h>
#include "version.h"

#ifndef VS_VERSION_INFO
#define VS_VERSION_INFO 1
#endif

#ifndef VS_FFI_FILEFLAGSMASK
#define VS_FFI_FILEFLAGSMASK 0x0000003FL
#endif

#ifndef VOS_NT_WINDOWS32
#define VOS_NT_WINDOWS32 0x00040004L
#endif

#ifndef VFT_APP
#define VFT_APP 0x00000001L
#endif

#ifndef VFT2_UNKNOWN
#define VFT2_UNKNOWN 0x00000000L
#endif

// Windows VERSIONINFO resource — provides file properties visible in
// Explorer → Properties → Details.

VS_VERSION_INFO VERSIONINFO
FILEVERSION    UPDATELOCK_VERSION_TUPLE
PRODUCTVERSION UPDATELOCK_VERSION_TUPLE
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0x0L
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404b0"   // Chinese Simplified (PRC) / Unicode
        BEGIN
            VALUE "CompanyName",      "bailong-Hakuryu / UpdateLock Contributors"
            VALUE "FileDescription",  "UpdateLock - Software Anti-Auto-Update Tool"
            VALUE "FileVersion",      UPDATELOCK_VERSION_STR "\0"
            VALUE "InternalName",     "UpdateLock\0"
            VALUE "LegalCopyright",   "Copyright (C) 2025-2026 bailong-Hakuryu. MIT License.\0"
            VALUE "OriginalFilename", "UpdateLock.exe\0"
            VALUE "ProductName",      "UpdateLock\0"
            VALUE "ProductVersion",   UPDATELOCK_VERSION_STR "\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0804, 1200   // Chinese Simplified / Unicode
    END
END
